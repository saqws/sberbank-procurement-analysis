# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/procurement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=procurement

# API Keys
EIS_API_KEY=your_eis_api_key_here
SPARK_API_KEY=your_spark_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Scraping Configuration
SELENIUM_HUB_URL=http://localhost:4444/wd/hub
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Rate Limiting
EIS_REQUESTS_PER_MINUTE=30
COMMERCIAL_DELAY_SECONDS=2

# Data Collection
START_DATE=2024-01-01
END_DATE=2025-12-31

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/procurement.log

# Analysis
ANOMALY_THRESHOLD=0.05
CORRELATION_MIN_THRESHOLD=0.3
